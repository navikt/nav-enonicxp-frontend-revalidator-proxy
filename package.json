{
  "name": "nav-enonicxp-frontend-cache-invalidator",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "scripts": {
    "start": "node dist/app.js",
    "dev": "nodemon --watch src --ext ts --exec \"pnpm run build && node -r dotenv/config dist/app.js\"",
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "nodemonConfig": {
    "delay": 500
  },
  "dependencies": {
    "express": "5.2.1",
    "pino": "^10.3.1",
    "redis": "5.12.1",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "@types/express": "5.0.4",
    "@types/node": "24.6.1",
    "dotenv": "17.4.2",
    "nodemon": "3.1.14",
    "prettier": "3.9.5",
    "typescript": "6.0.3"
  }
}